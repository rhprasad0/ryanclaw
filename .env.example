# Copy to .env and fill in values. .env is gitignored; this file is the
# public contract for what env vars the repo expects.

# --- Principle IV Path 1: Healthchecks.io heartbeat ---
# Ping URL for the 5-min home-server heartbeat.
HC_HEARTBEAT_URL=

# --- Principle IV Path 2: Synthetic Slack-delivery check ---
# Second Healthchecks.io ping URL. slack_synthetic_check.py pings it on
# webhook success (200/ok). Its absence is the alert.
HC_SYNTHETIC_URL=

# Agentic Hub incoming webhook URL for #sandbox (synthetic pings land here).
SLACK_SANDBOX_WEBHOOK_URL=

# Agentic Hub incoming webhook URL for #ops. Used by slack_synthetic_check.py
# to alert when the #sandbox webhook returns a non-200/non-ok response.
SLACK_OPS_WEBHOOK_URL=

# --- Existing crons ---
# Used by scripts/events_scout_cron.sh for failure alerts to #alerts.
SLACK_ALERTS_URL=

SLACK_BRIEFING_URL=